# ─── Supabase ───────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Anthropic ──────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
# Used for folder import / AI project extraction
ANTHROPIC_API_KEY=sk-ant-...

# ─── App auth (single-user shared password) ─────────────────
# Password the user types on /login; AUTH_SECRET is the cookie value set on success.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_PASSWORD=change-me
AUTH_SECRET=change-me-to-a-32-byte-random-value

# ─── Public base URL (OAuth redirects, absolute links) ──────
# Required for Gumroad / Etsy OAuth callbacks on preview deploys.
# Production: https://builder-os-xi.vercel.app
# Preview: https://<your-preview-url>.vercel.app
NEXT_PUBLIC_BASE_URL=https://builder-os-xi.vercel.app
